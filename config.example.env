# Copy to .env (or pass as real environment variables) and adjust.
# All values are optional; sensible defaults are shown.

# Where the server listens.
CLIPBOARD_HOST=0.0.0.0
CLIPBOARD_PORT=8470

# Public base URL used to build share links. Set this to your real domain when
# running behind a reverse proxy, e.g. https://clip.example.com
CLIPBOARD_BASE_URL=http://localhost:8470

# Where SQLite + encrypted blobs are stored (the contents are unreadable to the
# server, but back them up like any other data directory).
CLIPBOARD_DATA_DIR=./data

# Max size of the encrypted payload, in MB.
CLIPBOARD_MAX_MB=20

# Built-in math anti-bot check on create (1 = on, 0 = off).
CLIPBOARD_CAPTCHA=1

# Max create requests per IP per 10 minutes.
CLIPBOARD_RATE_CREATE=30

# Default expiry preselected in the UI: 1h | 1d | 7d | 30d | never
CLIPBOARD_DEFAULT_EXPIRY=7d
